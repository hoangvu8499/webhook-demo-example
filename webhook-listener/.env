# ─── Kafka ───────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=webhook-events
KAFKA_GROUP_ID=webhook-listener-group

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# pgxpool parameters can be appended as query string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/webhook_db?pool_max_conns=30&pool_min_conns=5

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Worker pool ──────────────────────────────────────────────────────────────
# Total concurrent HTTP delivery goroutines across all partitions.
# Rule of thumb: num_partitions * desired_concurrency_per_partition
# With 50 partitions, 200 gives ~4 concurrent deliveries per partition.
WORKER_COUNT=200

# ─── HTTP client ──────────────────────────────────────────────────────────────
HTTP_TIMEOUT=5s

# ─── Retry scheduler ──────────────────────────────────────────────────────────
# Base delay for exponential backoff: attempt 1 = 60s, attempt 2 = 120s
RETRY_BASE_DELAY=60s
# How often the scheduler polls webhook_events for due retries
RETRY_CHECK_INTERVAL=30s

# ─── Redis cache ──────────────────────────────────────────────────────────────
CACHE_TTL=10m
